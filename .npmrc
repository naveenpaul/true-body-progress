; Hoist babel-preset-expo (and any future babel preset/plugin) to the project's
; top-level node_modules so babel.config.js can require it directly. pnpm 10's
; default isolation hides transitive deps from the project root, which breaks
; EAS cloud builds where babel.config.js does require('babel-preset-expo').
public-hoist-pattern[]=*babel-preset-expo*
public-hoist-pattern[]=*babel-plugin-*
